# Twilio WhatsApp API
# 1. Crée un compte Twilio (gratuit pour tester) : https://www.twilio.com/try-twilio
# 2. Active le sandbox WhatsApp : https://console.twilio.com/us1/develop/sms/try-it-out/whatsapp-learn
# 3. Copie les valeurs ci-dessous

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO=whatsapp:+33626535244

# Stormglass API (marées) — gratuit, 10 req/jour
# Inscription : https://stormglass.io
STORMGLASS_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
